NODE_ENV=development
PORT=5000

# ── Database Provider: 'mongodb' | 'mysql' ──────────────
DB_PROVIDER=mongodb

# MongoDB (used when DB_PROVIDER=mongodb)
MONGO_URI=mongodb://localhost:27017/abmiti

# MySQL (used when DB_PROVIDER=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=abmiti


# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
